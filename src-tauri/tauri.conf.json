{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HALO CTI",
  "version": "0.2.0",
  "identifier": "com.halocti.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HALO CTI",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0MDVDMTYxQkYyRDM0MApSV1JBMC9JYkZseEFEd0tjazBLRUtKY3BMTDBrcjdHUWJyWnVoSzFMek4wTll0NmhJTG00NG03bQo=",
      "endpoints": [
        "https://github.com/Office-HALO/halo-cti-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
